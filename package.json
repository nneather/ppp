{
	"name": "ppp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"supabase:deploy-pdf": "supabase functions deploy generate-invoice-pdf",
		"supabase:send-invoice": "supabase functions deploy send-invoice",
		"supabase:deploy-functions": "supabase functions deploy generate-invoice-pdf && supabase functions deploy send-invoice",
		"supabase:start": "supabase start",
		"supabase:stop": "supabase stop",
		"supabase:db:reset": "supabase db reset",
		"supabase:migration:up": "supabase migration up"
	},
	"devDependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.0",
		"@supabase/supabase-js": "^2.102.1"
	}
}
