# ppp — prod project config for CLI scripts (copy to .env; safe to keep local)
# Dashboard → project → Settings → General → Reference ID
SUPABASE_REF=your-prod-project-ref

# ---------------------------------------------------------------------------
# .env.local (create separately — NOT this file) holds prod secrets + client config:
#
#   PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   PUBLIC_SUPABASE_ANON_KEY=<anon key — safe to publish, RLS is the boundary>
#   RESEND_API_KEY=<Resend key for send-invoice local dev>
#   ANTHROPIC_API_KEY=<optional — mirror of Supabase Edge secret, local OCR dev only>
#   LIBRARY_SRC_DATABASE_URL=<Postgres URI — Dashboard → Connect → Direct>
#   LIBRARY_DST_DATABASE_URL=<Postgres URI — Dashboard → Connect → Direct>
#   LIBRARY_MIGRATE_CONFIRM=<see scripts/library-migrate-local-to-prod/README.md>
#
# Full env table + rules: AGENTS.md › Environment variables.
# Edge Function secrets live in Supabase (`supabase secrets set`) — .env.local
# is local-dev mirror only.
